#include <iostream>
using namespace std;
int main()
{
	setlocale(0, "");
	int mapsize, choice;
	char texture;
	cout << "фигура квадрат" << endl;
	cout << "[1] - пустой внутри(dead inside)" << endl;
	cout << "[2] - заполненный" << endl;
	cout << "выбери: ";
	cin >> choice;
	cout << "введи размер: ";
	cin >> mapsize;
	cout << "введи текстуру: ";
	cin >> texture;
	int b = mapsize / 2;
	switch (choice) {
	case 1: {
			for (int x = 0; x < mapsize; x++) {
				for (int y = 0; y < mapsize; y++) {
					if (x / b == 0 or y / b == 0) {
						cout << " .";
					}
					else {
						if (x == b or x == mapsize - 1 or y == b or y == mapsize - 1) {
							cout << " " << texture;
						}
						else {
							cout << " .";
						}
					}
				}
				cout << endl;
			}
			break;
	}
	case 2: {
		for (int x = 0; x < mapsize; x++) {
			for (int y = 0; y < mapsize; y++) {
				if (x / b == 0 or y / b == 0) {
					cout << " .";
				}
				else {
					cout << " " << texture;
				}
			}
			cout << endl;
		}
	}
	}
		return 0;
	}

