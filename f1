#include <iostream>
using namespace std;
int main()
{
	setlocale(0, "");
	int mapsize;
	char texture;
	cout << "фигура змейка" << endl;
	cout << "введи размер: ";
	cin >> mapsize;
	cout << "введи текстуру: ";
	cin >> texture;
	int b = mapsize / 2;
	for (int x = 0; x < mapsize; x++) {
		for (int y = 0; y < mapsize; y++) {
			if (x / b == 0 or y / b == 0) {
				cout << " .";
			}
			else {
				if (x == b or x == mapsize - 1 or y == b or y == mapsize - 1) {
					cout << " " << texture;
				}
				else {
					cout << " .";
				}
			}
		}
			cout << endl;
		}
		return 0;
	}
