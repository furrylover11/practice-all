double calc(float num1, float num2, int op) {
	switch (op) {
	case 1: {
		return num1 + num2;
		break;
	}
	case 2: {
		return num1 - num2;
		break;
	}
	case 3: {
		return num1 * num2;
		break;
	}
	case 4: {
		return num1 / num2;
		break;
	}
	case 5: {
		return int(num1) % int(num2);
		break;
	}
	case 6: {
		return pow(num1, num2);
		break;
	}
	case 7: {
		return pow(num1, (1 / num2));
		break;
	}
	case 8: {
		return pow(num1, 3);
		break;
	}
	}
}
